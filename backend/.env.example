# ─────────────────────────────────────────────────────────────────────────────
# Tech News Chatbot — Environment Variables
# Copy this file to .env and fill in your keys.  Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq LLM (REQUIRED for AI chat features) ─────────────────────────────────
# Get your free API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Model used for intent classification  (fast, small)
GROQ_INTENT_MODEL=llama-3.1-8b-instant

# Model used for streaming chat responses  (high quality)
GROQ_STREAM_MODEL=llama-3.3-70b-versatile

# Fallback model when the primary stream model hits rate limits
GROQ_FALLBACK_STREAM_MODEL=llama-3.1-8b-instant


# ── News API providers ────────────────────────────────────────────────────────
# The Guardian (REQUIRED for historical news)
# Get your free key at: https://open-platform.theguardian.com/access/
# Free tier: 500 requests/day
GUARDIAN_API_KEY=your_guardian_api_key_here

# NewsAPI.org (OPTIONAL – increases general news coverage)
# Get your key at: https://newsapi.org/
NEWSAPI_API_KEY=your_newsapi_org_key_here

# NewsAPI.ai (OPTIONAL – increases coverage further)
# Get your key at: https://newsapi.ai/
NEWSAPIAI_API_KEY=your_newsapiai_key_here


# ── Stock / Finance providers ─────────────────────────────────────────────────
# Alpha Vantage (stock price data)
# Get your free key at: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# Finnhub (real-time quotes & company profile)
# Get your free key at: https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_key_here

# Polygon.io (market data – reserved for future use)
# Get your key at: https://polygon.io/
POLYGON_API_KEY=your_polygon_key_here


# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file.  The data/ directory is created on startup.
# Default (Docker / local): data/news.db
# DB_PATH=data/news.db
